# --- Database (Railway provisions this automatically) ---
DATABASE_URL="postgresql://user:pass@localhost:5432/agbro"

# --- Claude / Anthropic (the brain) ---
ANTHROPIC_API_KEY="sk-ant-..."
# Model used by agents for trade decisions & brain entries
AGBRO_MODEL="claude-opus-4-7"
AGBRO_FAST_MODEL="claude-haiku-4-5-20251001"

# --- Alpaca Markets (paper trading by default - NEVER enable live without review) ---
ALPACA_KEY_ID=""
ALPACA_SECRET_KEY=""
ALPACA_PAPER="true"   # "false" to go live. DO NOT flip this without explicit intent.

# --- Research ---
PERPLEXITY_API_KEY=""
GOOGLE_CSE_KEY=""
GOOGLE_CSE_CX=""

# --- App ---
APP_URL="http://localhost:3000"
APP_SINGLE_USER_MODE="true"     # MVP is single-user by design
AGBRO_CRON_SECRET=""             # shared secret for /api/cron/tick

# --- Safety rails ---
MAX_POSITION_PCT="15"            # no single position may exceed this % of portfolio
MAX_DAILY_TRADES="3"             # hard cap enforced server-side
MIN_CASH_RESERVE_PCT="10"        # always keep this % of principal in cash

# --- Database (Railway provisions this automatically) ---
DATABASE_URL="postgresql://user:pass@localhost:5432/agbro"

# --- Claude / Anthropic (the brain) ---
ANTHROPIC_API_KEY="sk-ant-..."
# Model used by agents for trade decisions & brain entries
AGBRO_MODEL="claude-opus-4-7"
AGBRO_FAST_MODEL="claude-haiku-4-5-20251001"

# --- Alpaca Markets (paper trading by default - NEVER enable live without review) ---
ALPACA_KEY_ID=""
ALPACA_SECRET_KEY=""
ALPACA_PAPER="true"   # "false" to go live. DO NOT flip this without explicit intent.

# --- Research ---
PERPLEXITY_API_KEY=""
GOOGLE_CSE_KEY=""
GOOGLE_CSE_CX=""

# --- App ---
APP_URL="http://localhost:3000"
AGBRO_CRON_SECRET=""             # shared secret for /api/cron/tick

# --- Auth (Auth.js v5) ---
# Generate via: openssl rand -base64 32
AUTH_SECRET=""
# Required in prod; in dev Auth.js falls back to APP_URL
AUTH_URL="http://localhost:3000"
# Resend magic-link email. Without a key, the magic link is printed to server logs (dev only).
RESEND_API_KEY=""
AGBRO_MAIL_FROM="AgBro <onboarding@resend.dev>"
# Optional allowlist — comma-separated. Leave empty to let any email sign in.
AGBRO_ALLOWED_EMAILS=""

# --- Rate limiting (optional) ---
# Without Upstash creds the limiter falls back to in-memory (per-instance) which
# is NOT safe for multi-instance deployments. Set these in prod.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Safety rails ---
MAX_POSITION_PCT="15"            # no single position may exceed this % of portfolio
MAX_DAILY_TRADES="3"             # hard cap enforced server-side
MIN_CASH_RESERVE_PCT="10"        # always keep this % of principal in cash

// AgBro data model.
// Single-user MVP (expandable) — tracks principal, trades, agent runs, strategy,
// the company "brain" and a comprehensive internal stock knowledge base.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------- User & Account --------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())

  account       Account?
  strategies    Strategy[]
  notes         UserNote[]
  notifications Notification[]

  // Auth.js relations
  accounts      AuthAccount[]
  sessions      Session[]

  // Ownership (per-user isolation)
  trades        Trade[]
  agentRuns     AgentRun[]
  brainEntries  BrainEntry[]
  auditLogs     AuditLog[]
  positions     Position[]
  optionPositions OptionPosition[]
  cryptoConfig  CryptoConfig?
  backtestRuns  BacktestRun[]
  apiCredentials UserApiCredential[]
  meetings      Meeting[]
}

// BYOK — per-user API keys for third-party providers. The raw key is
// NEVER stored; we encrypt it with AES-256-GCM (key derived from
// AGBRO_CREDENTIAL_ENCRYPTION_KEY env var) and store only the ciphertext
// + the last four chars for UI display. Unique on (userId, provider)
// so saving a new key for the same provider overwrites the old one.
model UserApiCredential {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // 'openai' | 'anthropic' | 'perplexity' | future: 'alpaca' etc
  encryptedKey String   @db.Text
  lastFour     String   // last 4 chars of the plaintext key, for masked UI display
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

// Auth.js: OAuth provider links (used if/when OAuth added; magic-link flow alone doesn't populate this).
// Mapped to table name "AuthAccount" to avoid collision with the trading Account domain model.
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("AuthAccount")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  principalCents      BigInt   @default(0)         // total money ever deposited
  depositedCents      BigInt   @default(0)         // cumulative deposits
  withdrawnCents      BigInt   @default(0)
  expectedAnnualPct   Float    @default(12.0)      // user-set target
  riskTolerance       String   @default("moderate") // conservative | moderate | aggressive
  isPaused            Boolean  @default(false)
  isStopped           Boolean  @default(false)
  maxPositionPct      Float    @default(15.0)
  maxDailyTrades      Int      @default(3)
  // ── Kill-switch rails ────────────────────────────────────────────
  // Daily P&L threshold (as pct of portfolio equity at market open).
  // If today's total return crosses this, the scheduler halts new
  // trades and flips isPaused → true with killSwitchReason set.
  // Default -5% is a generous ceiling — tighten per-user in /settings.
  // Zero or null disables the check.
  dailyLossKillPct    Float    @default(-5.0)
  // Cumulative drawdown from 30-day high that triggers a pause.
  // Different kind of protection than daily kill: catches grinding
  // declines (the 2022 pattern) that never hit a single bad day.
  // Default -15% keeps the agent running through normal corrections.
  drawdownPauseThresholdPct Float @default(-15.0)
  // Per-trade cap in cents. No single order can buy more than this
  // absolute dollar amount regardless of portfolio size — a backstop
  // against a bad price fetch or runaway sizing bug. Default $5k is
  // conservative for a $100k book; users scale it with deposits.
  maxTradeNotionalCents BigInt @default(500000)
  // Populated by the safety-rails module when a kill switch fires.
  // Not reset automatically — user must visit /settings and clear.
  // Presence of this field is how the UI decides to show the halt
  // banner (vs. a plain manual pause).
  killSwitchTriggeredAt DateTime?
  killSwitchReason    String?  @db.Text
  // Separate ceiling for rule-based crypto trades (DCA legs + rebalance
  // legs). Keeps the crypto engine's mechanical activity from eating into
  // the LLM agent's stock trade budget. Each DCA of a 3-coin allowlist
  // writes 3 Trade rows; without this split the agent's whole day of
  // trades could be burned by one crypto rebalance.
  maxDailyCryptoTrades Int      @default(10)
  minCashReservePct   Float    @default(10.0)
  tradingHoursStart   String   @default("09:45")    // ET, avoid the open bell
  tradingHoursEnd     String   @default("15:45")    // avoid the close
  agentCadenceMinutes Int      @default(60)         // how often an agent wakes up
  allowDayTrades      Boolean  @default(false)
  // When on, the screener auto-promotes candidates that clear a strict
  // Buffett-style bar (real EDGAR data + ROE well above threshold + low
  // leverage + fat margins + growing EPS) directly to the watchlist.
  // Off by default — conservative default keeps the human in the loop.
  autoPromoteCandidates Boolean @default(false)
  // Master switch for options trading. Off by default. Must be flipped ON
  // here AND the active strategy must list the specific setup (covered call
  // or cash-secured put) in its rules for the agent to place any option
  // order. Alpaca requires options approval on their side too; if this
  // toggle is on but Alpaca hasn't approved options, the server reports
  // the broker error back to the agent / user.
  optionsEnabled    Boolean  @default(false)
  // Master switch for the crypto module. Off by default. When off, the
  // crypto dashboard shows a "get started" state and no DCA / rebalance
  // runs. Crypto trades use a deterministic rule engine (NOT the LLM
  // agent) — Buffett's view on crypto is well known, and we don't have
  // evidence that LLM reasoning adds value in a market dominated by
  // narrative / macro / flows.
  cryptoEnabled     Boolean  @default(false)
  // Defensive rail: never let total crypto exposure exceed this % of total
  // portfolio value (stocks + options + crypto combined). Checked before
  // every DCA and rebalance-buy. When the cap is hit, underweight-crypto
  // buys are skipped; overweight-crypto sells (from rebalance or drift)
  // still execute since they REDUCE the exposure. Default 10% keeps crypto
  // as an asymmetric satellite for a Buffett-style core.
  maxCryptoAllocationPct Float @default(10.0)
  // AgBro-side "wallet" balance: cash the user has explicitly parked out
  // of the agent's reach. Alpaca still holds the underlying cash, but
  // place_trade + crypto DCA subtract this from effective buying power
  // before deciding what to deploy. Lets the user load $100k into Alpaca
  // but keep $50k "frozen" — the agent sees $50k. Transfers between
  // active and wallet are pure AgBro accounting, not real Alpaca moves.
  walletBalanceCents    BigInt   @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deposits            Deposit[]
}

model Deposit {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id])
  // Client-supplied (UUID). NULL for legacy rows created before idempotency
  // shipped; Postgres unique indexes treat NULLs as distinct by default, so
  // old rows never collide with each other or with new keyed rows.
  idempotencyKey  String?
  amountCents     BigInt
  note            String?
  createdAt       DateTime @default(now())

  @@unique([accountId, idempotencyKey])
}

// -------------------- Strategies --------------------

model Strategy {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  name         String
  isActive     Boolean  @default(false)
  version      Int      @default(1)
  summary      String   @db.Text
  rules        Json     // structured rules: sectors, pe_max, div_min, moat_required, etc.
  buffettScore Int      @default(0) // 0-100 internal "how Buffett-like"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  turns        StrategyTurn[]
}

// Conversational history for collaborative strategy wizard.
model StrategyTurn {
  id         String   @id @default(cuid())
  strategyId String
  strategy   Strategy @relation(fields: [strategyId], references: [id])
  role       String   // "user" | "agent"
  content    String   @db.Text
  createdAt  DateTime @default(now())
}

// -------------------- Trading --------------------

model Trade {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  alpacaOrderId String?    @unique
  symbol        String
  side          String     // "buy" | "sell"
  qty           Float
  fillPriceCents BigInt?
  submittedAt   DateTime   @default(now())
  filledAt      DateTime?
  status        String     // "pending" | "submitted" | "filled" | "rejected" | "canceled"
  errorMessage  String?    @db.Text
  orderType     String     @default("market")
  // Required for stock trades (LLM agent must write both cases). Null for
  // crypto DCA / rebalance trades, which are rule-based and don't carry a
  // thesis. The agent path still enforces non-null via the PlaceTradeInput
  // schema; relaxation is at the DB level only.
  bullCase      String?    @db.Text
  bearCase      String?    @db.Text
  thesis        String?    @db.Text
  marginOfSafetyPct Float?
  intrinsicValuePerShareCents BigInt?
  confidence    Float?      // 0..1 from the agent; null for rule-based trades
  // 'stock' | 'crypto'. Default keeps all pre-existing rows correct.
  assetClass    String     @default("stock")
  agentRunId    String?
  agentRun      AgentRun?   @relation(fields: [agentRunId], references: [id])
  strategyId    String?
  closedAt      DateTime?
  realizedPnlCents BigInt?  // set when closed
  notifications Notification[]

  @@index([userId, submittedAt])
}

model Position {
  id             String  @id @default(cuid())
  userId         String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol         String
  qty            Float
  avgCostCents   BigInt
  openedAt       DateTime @default(now())
  lastSyncedAt   DateTime @default(now())
  // Snapshot only for the above fields; source of truth is Alpaca.
  //
  // The fields below are AgBro-owned thesis metadata — Alpaca doesn't store
  // any of this. They answer "why do we own it, what's it worth, and when
  // do we need to re-check our assumptions?"
  //
  // thesis: original written rationale from place_trade. The exit evaluator
  //   quotes this back to the agent at re-review time.
  // targetPriceCents: agent's fair-value estimate at buy time. Populated for
  //   strategies that sell on price (Graham mean-reversion). Null = never
  //   sell on price alone (Buffett Core, Quality Compounders, etc).
  // holdingBias: 'forever' | 'long' | 'medium' | 'short'. Copied from the
  //   active strategy at buy time so the position exits under the rules it
  //   was entered under even if the user later switches strategies.
  // thesisReviewDueAt: forces a structured re-review on the next wake-up
  //   after this time. Set on open; bumped on every confirmed review.
  // openedUnderStrategyId: audit trail of which strategy opened this.
  // lastReviewedAt: set whenever the agent runs a thesis-review.
  thesis                String?   @db.Text
  targetPriceCents      BigInt?
  holdingBias           String?
  thesisReviewDueAt     DateTime?
  lastReviewedAt        DateTime?
  openedUnderStrategyId String?
  // 'stock' | 'crypto'. Crypto positions skip the thesis review / exit
  // evaluator entirely — crypto is rule-based, not LLM-driven.
  assetClass            String    @default("stock")

  @@unique([userId, symbol])
  @@index([userId, thesisReviewDueAt])
}

// -------------------- Crypto (rule-based) --------------------

// Per-user crypto automation config. One row per user. Deliberately simple
// for v1 — allowlist of symbols (Alpaca crypto format e.g. BTC/USD), target
// weights that sum to ≤ 100%, and a DCA schedule. No LLM involvement;
// engine is in src/lib/crypto/engine.ts.
model CryptoConfig {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Symbols the agent is allowed to trade. Alpaca format: "BTC/USD", "ETH/USD".
  // Empty list = DCA/rebalance no-op.
  allowlist             String[]
  // Target allocation by symbol, in percent (0..100). Keys must be a subset
  // of allowlist. Sum should be ≤ 100; any residual is held as cash.
  // Stored as JSON so it's schema-less and easy to edit.
  targetAllocations     Json     @default("{}")
  // DCA: every `dcaCadenceDays`, buy `dcaAmountCents` split across the
  // target allocations. Set dcaAmountCents=0 to disable DCA while keeping
  // the allowlist / config intact (lets user hold positions without
  // accumulating more).
  dcaAmountCents        BigInt   @default(0)
  dcaCadenceDays        Int      @default(7)
  lastDcaAt             DateTime?
  // Rebalance (v1.1): triggers when any holding drifts > rebalanceBandPct
  // from its target, capped at rebalanceCadenceDays since last rebalance.
  // Not used in v1 but fields are here so the UI can surface them.
  rebalanceBandPct      Float    @default(10)
  rebalanceCadenceDays  Int      @default(90)
  lastRebalancedAt      DateTime?
  // Strategy preset the user picked, if any. Values: 'btc_only' |
  // 'top3_core' | 'equal_weight_top3' | 'custom' (or null for legacy
  // configs before presets existed). Purely a UI label — the engine reads
  // allowlist / targetAllocations / rebalanceBandPct directly, so the
  // preset is just a snapshot of those fields at selection time plus a
  // human-readable tag for the dashboard.
  presetKey             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// -------------------- Agent runs & decisions --------------------

model AgentRun {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  trigger       String    // "schedule" | "manual" | "user_deposit" | "market_event"
  model         String    // always claude-opus-4-7 for trade decisions
  costUsd       Float?
  summary       String?   @db.Text
  status        String    @default("running") // running|completed|errored|skipped
  decision      String?   // "trade" | "hold" | "research_more" | "rebalance"
  errorMessage  String?   @db.Text
  trades        Trade[]
  decisions     AgentDecision[]
  researchNotes ResearchNote[]

  @@index([userId, startedAt])
}

// Granular reasoning steps / tool calls.
model AgentDecision {
  id         String   @id @default(cuid())
  agentRunId String
  agentRun   AgentRun @relation(fields: [agentRunId], references: [id])
  kind       String   // "tool_call" | "thought" | "final"
  payload    Json
  createdAt  DateTime @default(now())
}

model ResearchNote {
  id          String    @id @default(cuid())
  agentRunId  String?
  agentRun    AgentRun? @relation(fields: [agentRunId], references: [id])
  symbol      String?
  topic       String
  source      String    // "perplexity" | "google" | "internal" | "claude"
  bullCase    String?   @db.Text
  bearCase    String?   @db.Text
  summary     String    @db.Text
  rawExcerpt  String?   @db.Text
  scoreDelta  Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([symbol])
}

// -------------------- Company "Brain" --------------------

model BrainEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   // "weekly_update" | "post_mortem" | "lesson" | "principle" | "market_memo"
  title     String
  body      String   @db.Text
  tags      String[] @default([])
  relatedSymbols String[] @default([])
  createdAt DateTime @default(now())
  // Tracked so the /brain page can show "last synced X ago" for starter
  // entries. Prisma auto-bumps on any field change via @updatedAt.
  // @default(now()) backfills existing rows on first migration so the
  // NOT NULL constraint is satisfied without needing --force-reset.
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId, createdAt])
  @@index([kind])
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String   @db.Text
  createdAt DateTime @default(now())
}

// -------------------- Comprehensive Stock DB --------------------

// Internal universe + fundamentals cache. Seeded at install, enriched by agents.
model Stock {
  symbol         String   @id
  name           String
  sector         String?
  industry       String?
  marketCapCents BigInt?
  peRatio        Float?
  pbRatio        Float?
  dividendYield  Float?
  payoutRatio    Float?
  debtToEquity   Float?
  returnOnEquity Float?
  grossMarginPct Float?
  fcfYieldPct    Float?
  epsTTM                 Float?
  bookValuePerShare      Float?
  dividendPerShare       Float?
  sharesOutstanding      Float?
  epsGrowthPct5y         Float?
  // Where the numbers above came from. 'edgar' = authoritative SEC filing,
  // 'seed' = hand-entered starter value (may be stale/approximate), 'agent' =
  // the Claude agent updated it during a run, null = never refreshed.
  fundamentalsSource     String?
  fundamentalsUpdatedAt  DateTime?
  moatScore      Int?     // 0-100 internal, durable competitive advantage
  buffettScore   Int?     // 0-100 internal, Buffett-style fit
  notes          String?  @db.Text
  onWatchlist    Boolean  @default(false)
  // Three-tier universe. Rows with onWatchlist=true are the user-approved
  // hunting ground; rows with onWatchlist=false + candidateSource set are
  // agent-discovered Tier 2 candidates pending user approval or rejection.
  //   null            → the original 29-name seed universe
  //   'screener'      → found by screen_universe, pending user promote/reject
  //   'agent'         → added manually by the agent via update_stock_fundamentals
  //   'rejected'      → user said no; screener won't re-surface
  //   'watchlist'     → user promoted to main watchlist (onWatchlist also true)
  candidateSource String?
  candidateNotes  String?  @db.Text
  // One-sentence plain-English business description ("makes GPUs used in
  // AI training and gaming"). Surfaced on the /candidates review card so a
  // non-expert user knows what they're looking at without leaving the app.
  businessDescription String? @db.Text
  discoveredAt    DateTime?
  // Set when the screener auto-promoted this name to the watchlist on the
  // user's behalf (gated by Account.autoPromoteCandidates). Null for
  // user-approved or seed rows. Kept for audit + future "agent added these"
  // UI on the watchlist.
  autoPromotedAt  DateTime?
  // Next earnings report date (best-effort). Populated by an event-calendar
  // refresh — usually Perplexity-sourced and good to within a few days.
  // Used by the pre-trade earnings blackout + the home-page events card.
  nextEarningsAt  DateTime?
  earningsSource  String?   // 'perplexity' | 'edgar_predicted' | 'alpaca' | null
  earningsCheckedAt DateTime?
  lastAnalyzedAt DateTime?
  updatedAt      DateTime @updatedAt
  prices         PriceSnapshot[]
}

model PriceSnapshot {
  id         String   @id @default(cuid())
  symbol     String
  stock      Stock    @relation(fields: [symbol], references: [symbol])
  at         DateTime @default(now())
  priceCents BigInt
  source     String   @default("alpaca")

  @@index([symbol, at])
}

// -------------------- Options --------------------

// Short-option positions AgBro has opened. Only covered calls and cash-
// secured puts are allowed (enforced at the tool layer). Alpaca owns the
// broker-side truth (fills, expiration, assignment); this table mirrors
// the open position + the thesis behind it. When Alpaca stops reporting
// the contract, we mark status='closed' — a later iteration will
// distinguish expired-OTM vs. assigned by reading the activities feed.
model OptionPosition {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // OCC format symbol: e.g. AAPL250117C00200000. Unique across all users
  // is NOT guaranteed (different users can short the same contract) — so
  // we only uniquify with userId.
  optionSymbol      String
  underlyingSymbol  String
  contractType      String   // 'call' | 'put'
  // Which strategy we opened this under. Values: 'covered_call' |
  // 'cash_secured_put'. Anything else is rejected at the tool layer.
  setup             String
  strikeCents       BigInt
  expiration        DateTime
  // Number of contracts. 1 contract = 100 shares of underlying exposure.
  quantity          Int
  premiumPerContractCents BigInt   // credit received, per contract
  totalCreditCents  BigInt
  status            String   @default("open") // 'open' | 'closed' | 'expired_otm' | 'assigned'
  alpacaOrderId     String?
  thesis            String   @db.Text
  openedAt          DateTime @default(now())
  closedAt          DateTime?
  openedUnderStrategyId String?

  @@unique([userId, optionSymbol])
  @@index([userId, status])
  @@index([userId, expiration])
}

// Daily snapshot of a user's crypto book value. Alpaca's portfolio_history
// returns total equity (stocks + options + crypto), not crypto-only, so we
// build our own series by snapshotting on every cron tick that's been at
// least 23 hours since the last one. Starts sparse; over weeks/months it
// accumulates enough points to render a meaningful performance chart with
// a BTC benchmark overlay.
model CryptoBookSnapshot {
  id             String   @id @default(cuid())
  userId         String
  takenAt        DateTime @default(now())
  bookValueCents BigInt

  @@index([userId, takenAt])
}

// -------------------- Event calendar --------------------

// Macro + market-structure events the agent should be aware of. Per-symbol
// events (earnings, ex-div) live on the Stock row; this table is for
// cross-cutting dates: FOMC meetings, CPI prints, market closures.
// Seeded with known FOMC dates; Alpaca's free /v2/calendar syncs the market
// closure rows nightly.
model MarketEvent {
  id          String   @id @default(cuid())
  // 'fomc' | 'cpi' | 'market_closed' | 'market_early_close' | 'other'
  kind        String
  occursAt    DateTime
  description String
  createdAt   DateTime @default(now())

  @@index([occursAt])
  @@index([kind, occursAt])
}

// -------------------- Backtesting --------------------

// Point-in-time fundamentals for a symbol. Each row is "these were the
// numbers publicly known about this company AS OF `asOfDate`." Populated
// from SEC EDGAR's companyfacts feed quarter-by-quarter. Used by the
// backtester to evaluate strategy filters (P/E ≤ 22, ROE ≥ 15%, etc.)
// at historical decision dates WITHOUT look-ahead bias — i.e. a
// 2008-06-30 decision only sees fundamentals that were public by that
// date, not what the company reported months later.
model StockFundamentalsSnapshot {
  id              String   @id @default(cuid())
  symbol          String
  // "As of" is the date the fundamentals were publicly known. For
  // quarterly filings, we use the filing acceptance timestamp (when the
  // 10-Q hit EDGAR) rather than the period-end date.
  asOfDate        DateTime
  // Key metrics a strategy might filter on. All nullable — not every
  // company reports every concept every quarter, and XBRL tagging
  // coverage was spotty pre-2009.
  peRatio         Float?
  epsTTM          Float?
  returnOnEquity  Float?
  debtToEquity    Float?
  grossMarginPct  Float?
  dividendYield   Float?
  bookValuePerShare Float?
  sharesOutstanding Float?
  // Data source + when we fetched the row, so we can spot staleness
  // and target re-fetches if EDGAR adds historical data.
  source          String   @default("edgar")
  fetchedAt       DateTime @default(now())

  @@unique([symbol, asOfDate])
  @@index([symbol, asOfDate])
}

// A single backtest invocation. Captures the config that was run +
// the full results so the user can browse historical runs on /backtest
// and compare strategies side-by-side. Ephemeral-ish — we don't delete
// old runs automatically but nothing critical depends on them.
model BacktestRun {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Which rule set was simulated: 'buffett_core' | 'deep_value_graham' |
  // 'quality_compounders' | 'dividend_growth' | 'boglehead_index'.
  // Maps to the same preset keys used for the live strategies.
  strategyKey       String
  // Backtest mode — 'tier1' runs the deterministic rules only (original
  // proven behaviour); 'tier2' additionally screens the universe by
  // point-in-time fundamentals (EDGAR-derived ROE / P/E / D/E). Default
  // is tier1 to keep the safe path default.
  mode              String   @default("tier1")
  // Set when this run was part of the robustness grid so the UI can
  // place it in the right cell. Null for ad-hoc runs from the /backtest
  // single-run page. Matches keys in src/lib/backtest/windows.ts.
  windowKey         String?
  label             String?
  assetClass        String   @default("stock")
  universe          String[] @default([])
  benchmarkSymbol   String   @default("SPY")
  startDate         DateTime
  endDate           DateTime
  startingCashCents BigInt

  // Results. Null while status != 'completed'.
  endingEquityCents BigInt?
  benchmarkEndingCents BigInt?
  totalReturnPct    Float?
  benchmarkReturnPct Float?
  cagrPct           Float?
  sharpeAnnual      Float?
  maxDrawdownPct    Float?
  worstMonthPct     Float?
  tradeCount        Int?
  // Full equity series so the UI can render a chart.
  // Shape: [{t: epochMs, equity: number, benchmark: number}]
  equitySeries      Json?
  // Event log: every trade, rebalance, regime transition, etc.
  // Shape: [{date: 'YYYY-MM-DD', event: string, details: Record<string, unknown>}]
  eventLog          Json?

  status            String   @default("pending") // pending | running | completed | errored
  errorMessage      String?  @db.Text
  runAt             DateTime @default(now())
  completedAt       DateTime?

  @@index([userId, runAt])
  @@index([strategyKey])
  @@index([userId, strategyKey, windowKey])
}

// -------------------- Market regime tripwire --------------------

// Global market state derived from SPY price action. Recomputed on every
// cron tick. A new row is written ONLY when the regime transitions
// (calm → elevated, elevated → crisis, etc.) so the table doubles as
// an audit log of "when did we enter / leave each state."
//
// Used by the cron to force-wake every user agent the moment the
// market shifts away from calm — bypasses normal cadence + market-hours
// checks so the bot can't sleep through a flash crash. The agent reads
// the current regime from get_account_state and applies its strategy's
// crisis playbook when regime != 'calm'.
model MarketRegime {
  id                       String   @id @default(cuid())
  // 'calm' | 'elevated' | 'crisis' | 'recovery'
  regime                   String
  enteredAt                DateTime @default(now())
  spyDailyMovePct          Float?
  spyConsecutiveDownDays   Int?
  // List of human-readable trigger strings (e.g. "SPY -7.2% today",
  // "4 consecutive down days, -11.3% cumulative"). Stored as JSON
  // for flexibility — no schema change when we add new tripwires.
  triggers                 Json?

  @@index([enteredAt])
}

// -------------------- Notifications & Audit --------------------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tradeId   String?
  trade     Trade?   @relation(fields: [tradeId], references: [id])
  kind      String   // "trade_placed" | "trade_filled" | "agent_paused" | "weekly_update" | "error"
  title     String
  body      String   @db.Text
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actor     String   // "agent" | "user" | "system"
  action    String
  payload   Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// -------------------- Executive Meetings --------------------
//
// Weekly (or impromptu) meetings where "the firm" reviews the past
// week's trades, market regime, brain entries, and decides next-week
// priorities. One Claude call plays all the executive roles
// (Proposer / Skeptic / Validator / Meta) in a single multi-turn
// conversation → emits structured JSON with transcript + summary +
// action items + policy changes. Optionally a second step generates
// a comic-strip visual of the meeting via OpenAI image API using
// the user's own key.

model Meeting {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 'weekly' | 'impromptu' | 'monthly' (future). Users trigger
  // impromptu ones from the UI; weeklies come from the cron.
  kind          String   @default("weekly")
  // Agenda the meeting was given. Mostly the same each week but can
  // be customised per-run (e.g. an impromptu meeting on a specific topic).
  agendaJson    Json?
  // The full meeting output from Claude — transcript (turns by each
  // executive role), summary, decisions, sentiment. Shape documented
  // in src/lib/meetings/schema.ts.
  transcriptJson Json?
  summary       String?  @db.Text
  // Comic strip: URL stored remotely (OpenAI images are permanent URLs
  // but we should eventually mirror to our own storage). scriptJson
  // captures the screenplay we sent to OpenAI so the user can see the
  // full creative brief behind the comic.
  comicUrl      String?  @db.Text
  comicScriptJson Json?
  comicCostUsd  Float?
  // Populated when comic generation was attempted and failed. Null
  // while unattempted OR after a successful retry. Surfaced on the
  // meeting card so the user can see the actual failure reason.
  comicError    String?  @db.Text
  costUsd       Float?   // total (meeting LLM + comic script LLM + image)
  status        String   @default("running") // running | completed | errored
  errorMessage  String?  @db.Text
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  actionItems   MeetingActionItem[]
  policyChanges PolicyChange[]

  @@index([userId, startedAt])
}

model MeetingActionItem {
  id           String   @id @default(cuid())
  meetingId    String
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId       String   // denormalised for direct user queries
  // What kind of action this is — drives how / whether the agent
  // picks it up automatically on its next wake.
  //   'research'           — agent should research this symbol/topic
  //   'adjust_strategy'    — suggested param tweak, needs user to accept
  //   'review_position'    — flag a held position for the next evaluator pass
  //   'wait_for_data'      — agent should wait for earnings / filing / etc
  //   'note'               — informational; no executor
  kind         String
  description  String   @db.Text
  status       String   @default("started") // started | on_hold | completed | blocked
  // Link back to agent runs that executed this item (for 'research' etc).
  executedBy   String?  // AgentRun.id
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  completedAt  DateTime?

  @@index([userId, status])
  @@index([meetingId])
}

// Meetings can propose changes to strategy parameters, universes,
// cadences, etc. Users accept/reject these from the UI; on acceptance
// the change is applied to the live Strategy / CryptoConfig / Account
// rows. We keep the before/after so it's reversible.
model PolicyChange {
  id           String   @id @default(cuid())
  meetingId    String
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId       String
  kind         String   // 'strategy_param' | 'crypto_config' | 'account' | 'cadence' | 'universe'
  targetKey    String   // free-form identifier (e.g. 'strategy.buffett_core.minROE')
  before       Json?
  after        Json
  rationale    String   @db.Text
  status       String   @default("proposed") // proposed | accepted | rejected | applied
  decidedAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId, status])
}
